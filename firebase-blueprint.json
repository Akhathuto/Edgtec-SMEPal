{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the business owner and their company.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "companyName": { "type": "string" },
        "companyRegNumber": { "type": "string" },
        "taxNumber": { "type": "string" },
        "industry": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email"]
    },
    "Client": {
      "title": "Client",
      "description": "A business client or customer.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "vatNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "An invoice sent to a client.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid", "overdue"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "invoiceNumber", "total"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A business expense or scanned receipt.",
      "type": "object",
      "properties": {
        "merchant": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "taxAmount": { "type": "number" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["merchant", "amount", "date"]
    },
    "TaxScenario": {
      "title": "Tax Scenario",
      "description": "A saved tax calculation scenario.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "income": { "type": "number" },
        "expenses": { "type": "number" },
        "taxYear": { "type": "string" },
        "results": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "income"]
    },
    "MarketingDraft": {
      "title": "Marketing Draft",
      "description": "AI-generated marketing content.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/users/{userId}/clients/{clientId}": {
      "schema": "Client",
      "description": "Collection of clients for a specific user."
    },
    "/users/{userId}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Collection of invoices for a specific user."
    },
    "/users/{userId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of expenses for a specific user."
    },
    "/users/{userId}/taxScenarios/{scenarioId}": {
      "schema": "TaxScenario",
      "description": "Collection of tax scenarios for a specific user."
    },
    "/users/{userId}/marketingDrafts/{draftId}": {
      "schema": "MarketingDraft",
      "description": "Collection of marketing drafts for a specific user."
    }
  }
}
